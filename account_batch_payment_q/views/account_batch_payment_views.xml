<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_batch_payment_form" model="ir.ui.view">
        <field name="name">account.batch.payment.q.form</field>
        <field name="model">account.batch.payment</field>
        <field name="inherit_id" ref="account_batch_payment.view_batch_payment_form"/>
        <field name="arch" type="xml">
            <button id="validate_button" position="attributes">
                <attribute name="invisible" add="not is_checked" separator="or"/>
            </button>
            <field name="payment_method_id" position="after">
                <field name="is_checked" readonly="state != 'draft'" widget="boolean_toggle"/>
            </field>
            <field name="name" position="after">
                <field name="payment_count" readonly="True"/>
                <field name="payment_total_amount_signed" readonly="True"/>
            </field>
        </field>
    </record>
</odoo>
