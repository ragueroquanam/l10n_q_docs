<odoo>
    <data>
        <record id="approval_route_form_inherit_quanam" model="ir.ui.view">
            <field name="name">approval.route.form.inherit.quanam</field>
            <field name="model">approval.route</field>
            <field name="inherit_id" ref="xf_approval_route_base.approval_route_form"/>
            <field name="arch" type="xml">
                <field name="active" position="after">
                    <field name="is_default"/>
                </field>
            </field>
        </record>

        <record id="approval_route_list_inherit_quanam" model="ir.ui.view">
            <field name="name">approval.route.list.inherit.quanam</field>
            <field name="model">approval.route</field>
            <field name="inherit_id" ref="xf_approval_route_base.approval_route_list"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <field name="is_default_label"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
