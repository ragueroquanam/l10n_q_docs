<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="inherit_view_stock_quant_tree_inventory_editable" model="ir.ui.view">
        <field name="name">stock.quant.inventory.list.editable.inherit</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_id']" position="before">
                <field name="location_id_domain" column_invisible="True"/>
            </xpath>

            <xpath expr="//field[@name='location_id']" position="attributes">
                <attribute name="domain">location_id_domain</attribute>
            </xpath>

        </field>
    </record>

</odoo>