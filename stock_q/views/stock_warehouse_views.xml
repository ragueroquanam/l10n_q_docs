<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_warehouse_form_responsable" model="ir.ui.view">
        <field name="name">stock.warehouse.form.responsable</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="responsible_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <record id="stock.action_warehouse_form" model="ir.actions.act_window">
        <field name="context">{'from_action_warehouse_form': 1}</field>
    </record>
    <record id="stock.menu_warehouse_report" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>
</odoo>