<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_tree_inherit_session_id" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.session</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="session_id" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_search_inherit_session_id" model="ir.ui.view">
        <field name="name">account.move.search.inherit.session</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='date']" position="before">
                <field name="session_id" string="Sesión de Caja"/>
            </xpath>

            <xpath expr="//filter[@name='by_company']" position="inside">
                <filter string="Sesión de Caja" name="by_session" context="{'group_by': 'session_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_tree_inherit_session" model="ir.ui.view">
        <field name="name">account.move.line.tree.inherit.session</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <field name="move_name" position="after">
                <field name="session_id" optional="hide"/>
            </field>
        </field>
    </record>


    <record id="view_account_move_line_filter_inherit_session" model="ir.ui.view">
        <field name="name">account.move.line.search.inherit.session</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_account_move_line_filter"/>
        <field name="arch" type="xml">
            <field name="journal_id" position="after">
                <field name="session_id"/>
            </field>
            <xpath expr="//group" position="inside">
                <filter string="Sesión de Caja" name="group_by_session" context="{'group_by': 'session_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="account.action_move_journal_line" model="ir.actions.act_window">
        <field name="context">{'from_account_move_menu': True, 'default_move_type': 'entry', 'search_default_posted':1, 'view_no_maturity': True}</field>
    </record>
</odoo>
