<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View cash.management.payment.method View List -->
    <record id="view_cash_management_payment_method_list" model="ir.ui.view">
        <field name="name">view.cash.management.payment.method.list</field>
        <field name="model">cash.management.payment.method</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="journal_id"/>
                <field name="payment_method_in_id"/>
                <field name="payment_method_out_id"/>
                <field name="company_id"/>
                <field name="currency_id"/>
            </list>
        </field>
    </record>

    <!-- View cash.management.payment.method form -->
    <record id="view_cash_management_payment_method_form" model="ir.ui.view">
        <field name="name">view.cash.management.payment.method.form</field>
        <field name="model">cash.management.payment.method</field>
        <field name="arch" type="xml">
            <form string="Cash Management Payment Method">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="journal_id"/>
                            <field name="payment_method_in_id" domain="payment_method_in_domain" widget="many2many_tags"/>
                            <field name="payment_method_out_id" domain="payment_method_out_domain" widget="many2many_tags"/>
                            <field name="currency_id" readonly="True" force_save="1"/>
                            <field name="outstanding_account_id" invisible="not is_journal_bank"
                                   required="is_journal_bank"/>
                            <field name="receivable_account_id"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action cash.management.payment.method -->
    <record id="action_cash_management_payment_method" model="ir.actions.act_window">
        <field name="name">Diarios de caja</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cash.management.payment.method</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
