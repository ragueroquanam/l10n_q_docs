<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View cash.management.bill View List -->
    <record id="view_cash_management_bill_list" model="ir.ui.view">
        <field name="name">view.cash.management.bill.list</field>
        <field name="model">cash.management.bill</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name" string="Nombre"/>
                <field name="value"/>
                <field name="is_for_all_config"/>
                <field name="config_ids" force_save="1" widget="many2many_tags" readonly="is_for_all_config"/>
            </list>
        </field>
    </record>

    <!-- Action cash.management.bill -->
    <record id="action_cash_management_bill" model="ir.actions.act_window">
        <field name="name">Monedas/Billetes</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cash.management.bill</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
