<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View cash.management.config View List -->
    <record id="view_cash_management_config_list" model="ir.ui.view">
        <field name="name">view.cash.management.config.list</field>
        <field name="model">cash.management.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="is_cash_control"/>
                <field name="payment_method_id" widget="many2many_tags"/>
                <field name="currency_id"/>
                <field name="employee_ids" widget="many2many_tags"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <!-- View cash.management.config form -->
    <record id="view_cash_management_config_form" model="ir.ui.view">
        <field name="name">view.cash.management.config.form</field>
        <field name="model">cash.management.config</field>
        <field name="arch" type="xml">
            <form string="Cash Management Config">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" string="Nombre"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="is_cash_control"/>
                            <field name="payment_method_id" domain="payment_method_id_domain" widget="many2many_tags"/>
                            <field name="journal_id" required="True"/>
                            <field name="currency_id"/>
                            <field name="parent_id" />
                            <field name="child_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="employee_ids" widget="many2many_tags"/>
                            <field name="cash_transfer_account_id"/>
                            <field name="payment_method_id_domain" invisible="1"/>
                            <field name="bank_transfer_journal_ids" widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Seleccione los diarios para transferencias a banco"/>
                            <field name="cash_transfer_target_ids" widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Seleccione cajas destino para transferencia de efectivo desde esta caja."/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action cash.management.config -->
    <record id="action_cash_management_config" model="ir.actions.act_window">
        <field name="name">Cajas</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cash.management.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
