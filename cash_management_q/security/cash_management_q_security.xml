<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_cash_management_q_config" model="res.groups">
            <field name="name">Configuración</field>
            <field name="category_id" ref="cash_management_q.module_category_cash_management_q"/>
        </record>

        <!-- Grupo: Caja - Usuario -->
        <record id="group_cash_management_user" model="res.groups">
            <field name="name">Usuario</field>
            <field name="category_id" ref="cash_management_q.module_category_cash_management_q"/>
        </record>

        <!-- Grupo: Caja - Responsable -->
        <record id="group_cash_management_responsible" model="res.groups">
            <field name="name">Responsable</field>
            <field name="category_id" ref="cash_management_q.module_category_cash_management_q"/>
        </record>

        <!-- Reglas para la caja-->
<!--        <record id="rule_cash_config_user_or_responsible" model="ir.rule">-->
<!--            <field name="name">Caja: solo acceso si soy el usuario asignado</field>-->
<!--            <field name="model_id" ref="model_cash_management_config"/>-->
<!--            <field name="groups" eval="[(4, ref('cash_management_q.group_cash_management_user'))]"/>-->
<!--            <field name="domain_force">[('employee_ids.user_id', '=', user.id)]</field>-->
<!--        </record>-->

        <record id="rule_cash_config_responsible_group" model="ir.rule">
            <field name="name">Caja: acceso grupo responsable</field>
            <field name="model_id" ref="model_cash_management_config"/>
            <field name="groups" eval="[(4, ref('cash_management_q.group_cash_management_responsible'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>

        <record id="rule_cash_config_company_rule" model="ir.rule">
            <field name="name">Caja regla multi-compañía</field>
            <field name="model_id" ref="model_cash_management_config"/>
            <field name="domain_force">['|', ('company_id', 'parent_of', company_ids), ('company_id', '=', False)]
            </field>
        </record>

        <!-- Reglas para Diarios de pago de la caja-->

        <record id="rule_management_payment_method_company_rule" model="ir.rule">
            <field name="name">Diarios pago caja regla multi-compañía</field>
            <field name="model_id" ref="model_cash_management_payment_method"/>
            <field name="domain_force">['|', ('company_id', 'parent_of', company_ids), ('company_id', '=', False)]
            </field>
        </record>


        <!-- Reglas para la Sesión-->
        <record id="rule_cash_session_user_or_responsible" model="ir.rule">
            <field name="name">Sesión: solo acceso si soy el usuario asignado</field>
            <field name="model_id" ref="model_cash_management_session"/>
            <field name="groups" eval="[(4, ref('cash_management_q.group_cash_management_user'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
        </record>

        <record id="rule_cash_session_responsible_group" model="ir.rule">
            <field name="name">Sesión: acceso grupo responsable</field>
            <field name="model_id" ref="model_cash_management_session"/>
            <field name="groups" eval="[(4, ref('cash_management_q.group_cash_management_responsible'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>

        <record id="rule_cash_session_company_rule" model="ir.rule">
            <field name="name">Sesión regla multi-compañía</field>
            <field name="model_id" ref="model_cash_management_session"/>
            <field name="domain_force">['|', ('company_id', 'parent_of', company_ids), ('company_id', '=', False)]
            </field>
        </record>
    </data>
</odoo>
