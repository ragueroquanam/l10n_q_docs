<odoo>

    <record id="view_cash_config_set_parent_wizard" model="ir.ui.view">
        <field name="name">cash.config.set.parent.wizard.form</field>
        <field name="model">cash.config.set.parent.wizard</field>
        <field name="arch" type="xml">
            <form string="Asignar Caja Padre">
                <group>
                    <field name="parent_id" readonly="1"/>
                    <field name="config_ids" readonly="1"/>
                </group>
                <footer>
                    <button name="action_set_parent" type="object" string="Asignar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_cash_config_set_parent_wizard" model="ir.actions.server">
        <field name="name">Asignar Caja Padre</field>
        <field name="model_id" ref="cash_management_q.model_cash_management_config"/>
        <field name="binding_model_id" ref="cash_management_q.model_cash_management_config"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = {
            'type': 'ir.actions.act_window',
            'name': 'Asignar Caja Padre',
            'res_model': 'cash.config.set.parent.wizard',
            'view_mode': 'form',
            'target': 'new',
            'context': {'active_ids': records.ids},
            }
        </field>
    </record>


</odoo>
