<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista del wizard principal -->
    <record id="view_multi_invoice_payment_wizard_form" model="ir.ui.view">
        <field name="name">multi.invoice.payment.wizard.pos.form</field>
        <field name="model">multi.invoice.payment.wizard</field>
        <field name="inherit_id" ref="account_q.view_multi_invoice_payment_wizard_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='total_amount_residual']" position="after">
                <field name="session_id" domain="session_id_domain" options="{'no_create':True, 'no_open':True}"
                       invisible="not show_session_field" required="show_session_field"/>
            </xpath>
        </field>
    </record>
</odoo>
