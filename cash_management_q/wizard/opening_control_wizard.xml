<odoo>

    <record id="view_cash_management_opening_control_wizard_form" model="ir.ui.view">
        <field name="name">cash.management.opening.control.wizard.form</field>
        <field name="model">cash.management.opening.control.wizard</field>
        <field name="arch" type="xml">
            <form string="Control de Apertura de Caja">
                <group>
                    <field name="balance_start" widget="monetary" readonly="1"/>
                    <field name="document_balance" widget="monetary" readonly="1"/>
                    <label for="total_amount"/>
                    <div class="d-flex gap-2">
                        <field name="total_amount" widget="monetary" readonly="1" class="w-25"/>
                        <span class="d-flex gap-2 w-100">
                            <button name="action_open_cash_breakdown"
                                    type="object"
                                    icon="fa-money"
                                    string=""
                                    class="btn btn-secondary"
                                    title="Desglose de Billetes y Monedas"
                                    invisible="not is_cash_control"/>
                        </span>
                    </div>
                    <field name="opening_note"/>
                </group>

                <footer>
                    <button name="button_confirm" string="Abrir caja registradora" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>


    <record id="view_cash_management_opening_breakdown_wizard_form" model="ir.ui.view">
        <field name="name">cash.management.opening.breakdown.wizard.form</field>
        <field name="model">cash.management.opening.breakdown.wizard</field>
        <field name="arch" type="xml">
            <form string="Desglose de Billetes y Monedas">
                <group>
                    <group>
                        <field name="balance_start" readonly="1"/>
                    </group>
                    <group>
                        <field name="total" readonly="1"/>
                    </group>
                </group>
                <group string="Detalle de Billetes y Monedas">
                    <field name="breakdown_line_ids" nolabel="1">
                        <list editable="bottom" create="false" delete="false">
                            <field name="bill_id" readonly="1"/>
                            <field name="quantity" widget="numeric-step"/>
                            <field name="value" readonly="1"/>
                        </list>
                    </field>
                </group>

                <footer>
                    <button name="action_confirm_breakdown" type="object"
                            string="Confirmar" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cash_management_opening_control_wizard" model="ir.actions.act_window">
        <field name="name">Control de Apertura</field>
        <field name="res_model">cash.management.opening.control.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
