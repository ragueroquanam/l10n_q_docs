<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_automatic_debit_payment_wizard_form" model="ir.ui.view">
        <field name="name">automatic.debit.payment.wizard.form</field>
        <field name="model">automatic.debit.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Pagos por Débito Automático">
                <group>
                    <field name="journal_id"/>
                    <field name="payment_method_line_ids" widget="many2many_tags" domain="[('journal_id', '=', journal_id), ('payment_type', '=', 'inbound')]"/>
                    <field name="payment_date"/>
                    <field name="invoice_count" readonly="1"/>
                </group>
                <footer>
                    <button name="action_generate_payments" type="object" string="Generar Pagos" class="btn-primary"
                    invisible="invoice_count &gt;= 1000"/>
                    <button name="action_enqueue_payment_job" type="object" string="Generar Pagos Segundo Plano"
                            invisible="invoice_count &lt; 1000" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_automatic_debit_payment_wizard" model="ir.actions.act_window">
        <field name="name">Generar Pagos por Débito Automático</field>
        <field name="res_model">automatic.debit.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_action_automatic_debit_payment_wizard"
              name="Pagos por Débito Automático"
              parent="account.menu_finance_receivables"
              action="action_automatic_debit_payment_wizard"
              sequence="19"/>
</odoo>