<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_account_form_inherit" model="ir.ui.view">
        <field name="name">partner.account.form.inherit.partner_account_currency</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='accounting']//group[@name='accounting_entries']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <field name="property_account_payable_id" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="property_account_receivable_id" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <xpath expr="//group[@name='accounting_entries']" position="after">
                <group string="Asientos Contables por Moneda" name="partner_account"
                       groups="account.group_account_readonly">
                    <field name="partner_account_ids" nolabel="1" colspan="2">
                        <list editable="bottom">
                            <field name="company_id"/>
                            <field name="currency_id"/>
                            <field name="account_receivable_id" required="account_payable_id == False"/>
                            <field name="account_payable_id" required="account_receivable_id == False"/>
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>
</odoo>