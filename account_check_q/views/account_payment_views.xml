<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form" model="ir.ui.view">
        <field name="name">account.payment.view.form.inherit.check</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group2']//field[@name='payment_method_line_id']" position="after">
                <field name="payment_method_is_check" invisible="1"/>
                <field name="check_number" invisible="not payment_method_is_check" required="payment_method_is_check"/>
                <field name="check_due_date" invisible="not payment_method_is_check" required="payment_method_is_check"/>
            </xpath>
        </field>
    </record>
    <record id="view_account_payment_tree_inherit_check_fields" model="ir.ui.view">
        <field name="name">account.payment.tree.inherit.check_fields</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="check_number" optional="hide"/>
                <field name="check_due_date" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>