<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_account_position_form_inherit" model="ir.ui.view">
            <field name="name">view.account.position.form.inherit.product_mapping</field>
            <field name="model">account.fiscal.position</field>
            <field name="inherit_id" ref="account.view_account_position_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page name="product_mapping" string="Mapeo de productos">
                        <field name="product_map_ids" widget="one2many" nolabel="1"  context="{'append_type_to_tax_name': True}">
                            <list name="product_list" editable="bottom">
                                <field name="product_id"/>
                                <field name="tax_id"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>