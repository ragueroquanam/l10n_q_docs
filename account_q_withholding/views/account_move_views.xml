<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_account_move_form_inherit" model="ir.ui.view">
            <field name="name">view.account.move.form.inherit.recalculate_retention</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@class='oe_subtotal_footer']" position="before">
                    <div style="text-align: right;">
                        <button name="button_update_tax_totals" type="object" string="Actualizar" class="oe_link"
                                icon="fa-refresh" invisible="move_type != 'in_invoice' or state != 'draft'"/>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>