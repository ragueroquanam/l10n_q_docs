<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit customer invoice form view to add barcode fields -->
    <record id="view_move_form_inherit_barcode" model="ir.ui.view">
        <field name="name">account.move.form.inherit.barcode</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_reference']" position="after">
                <field name="file_barcode" invisible="move_type not in ('out_invoice','out_refund','out_receipt')"/>
            </xpath>
        </field>
    </record>
</odoo>

