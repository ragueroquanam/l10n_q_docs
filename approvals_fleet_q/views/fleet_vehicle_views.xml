<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_fleet_service_types_tree_inherit" model="ir.ui.view">
            <field name="name">view.fleet.service.types.tree.inherit.fuel_service</field>
            <field name="model">fleet.service.type</field>
            <field name="inherit_id" ref="fleet.fleet_vehicle_service_types_view_tree"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='category']" position="after">
                    <field name="is_fuel_service"/>
                </xpath>
            </field>
        </record>
        <record id="view_fleet_vehicle_log_services_form_inherit" model="ir.ui.view">
            <field name="name">view.fleet.vehicle.log.services.form.inherit.quantity</field>
            <field name="model">fleet.vehicle.log.services</field>
            <field name="inherit_id" ref="fleet.fleet_vehicle_log_services_view_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('o_row')]" position="after">
                    <field name="quantity" readonly="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>