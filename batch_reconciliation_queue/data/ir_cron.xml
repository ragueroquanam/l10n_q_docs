<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.cron" forcecreate="True" id="ir_cron_check_master_reconciled">
        <field name="name">Reconciliation Master: Chequeo de Master Reconciled</field>
        <field name="model_id" ref="batch_reconciliation_queue.model_batch_reconciliation_master" />
        <field name="state">code</field>
        <field name="code">model.check_complete_reconciled()</field>
        <field name="user_id" ref="base.user_root" />
        <field name="interval_number">20</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True" />
    </record>
</odoo>
