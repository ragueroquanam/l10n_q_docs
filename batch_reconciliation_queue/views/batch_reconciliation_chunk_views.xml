<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Chunk: List View -->
    <record id="batch_reconciliation_chunk_view_list" model="ir.ui.view">
        <field name="name">batch.reconciliation.chunk.list</field>
        <field name="model">batch.reconciliation.chunk</field>
        <field name="arch" type="xml">
            <list string="Reconciliation Chunks" decoration-success="state == 'done'" decoration-danger="state == 'failed'" decoration-info="state == 'processing'" decoration-muted="state == 'cancelled'" create="0">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="master_id"/>
                <field name="payment_count"/>
                <field name="processed_payments"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-danger="state == 'failed'" decoration-info="state == 'processing'"/>
                <field name="created_line_count"/>
                <field name="reconciled_count"/>
                <field name="duration" widget="float_time"/>
                <field name="retry_count"/>
                <field name="start_time"/>
            </list>
        </field>
    </record>

    <!-- Chunk: Form View -->
    <record id="batch_reconciliation_chunk_view_form" model="ir.ui.view">
        <field name="name">batch.reconciliation.chunk.form</field>
        <field name="model">batch.reconciliation.chunk</field>
        <field name="arch" type="xml">
            <form string="Reconciliation Chunk" create="0">
                <header>
                    <button name="action_retry" string="Retry" type="object" class="btn-warning" invisible="state != 'failed'"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary" invisible="state not in ('pending', 'failed')"/>
                    <button name="action_view_master" string="View Master Job" type="object" class="btn-link"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,processing,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Chunk Information">
                            <field name="master_id"/>
                            <field name="sequence"/>
                            <field name="st_line_id"/>
                            <field name="company_id"/>
                        </group>
                        <group string="Payment Data">
                            <field name="payment_count"/>
                            <field name="processed_payments"/>
                        </group>
                    </group>
                    <group>
                        <group string="Results">
                            <field name="created_line_count"/>
                            <field name="reconciled_count"/>
                        </group>
                        <group string="Timing">
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="duration" widget="float_time"/>
                            <field name="retry_count"/>
                        </group>
                    </group>
                    <group string="Error Details" invisible="state != 'failed'">
                        <field name="error_message" colspan="2" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Chunk: Search View -->
    <record id="batch_reconciliation_chunk_view_search" model="ir.ui.view">
        <field name="name">batch.reconciliation.chunk.search</field>
        <field name="model">batch.reconciliation.chunk</field>
        <field name="arch" type="xml">
            <search string="Search Chunks">
                <field name="name"/>
                <field name="master_id"/>
                <separator/>
                <filter name="filter_pending" string="Pending" domain="[('state', '=', 'pending')]"/>
                <filter name="filter_processing" string="Processing" domain="[('state', '=', 'processing')]"/>
                <filter name="filter_done" string="Completed" domain="[('state', '=', 'done')]"/>
                <filter name="filter_failed" string="Failed" domain="[('state', '=', 'failed')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_master" string="Master Job" context="{'group_by': 'master_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Chunk: Action -->
    <record id="action_batch_reconciliation_chunk" model="ir.actions.act_window">
        <field name="name">Reconciliation Chunks</field>
        <field name="res_model">batch.reconciliation.chunk</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="batch_reconciliation_chunk_view_search"/>
        <field name="context">{'search_default_filter_processing': 1, 'search_default_filter_pending': 1}</field>
    </record>

</odoo>
