<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_payment_terminal_tree" model="ir.ui.view">
        <field name="name">pos.payment.terminal.tree</field>
        <field name="model">pos.payment.terminal</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="pos_id"/>
                <field name="branch"/>
                <field name="client_app_id"/>
                <field name="provider_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pos_payment_terminal_form" model="ir.ui.view">
        <field name="name">pos.payment.terminal.form</field>
        <field name="model">pos.payment.terminal</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="pos_id"/>
                        <field name="branch"/>
                        <field name="client_app_id"/>
                        <field name="provider_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_payment_terminal_search" model="ir.ui.view">
        <field name="name">pos.payment.terminal.search</field>
        <field name="model">pos.payment.terminal</field>
        <field name="arch" type="xml">
            <search>
                <field name="pos_id"/>
                <field name="branch"/>
                <field name="client_app_id"/>
                <field name="provider_id" filter_domain="[]" string="Proveedor"/>
                <filter name="group_by_provider" string="Agrupar por Proveedor" context="{'group_by': 'provider_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_pos_payment_terminal" model="ir.actions.act_window">
        <field name="name">Terminales de Pago</field>
        <field name="res_model">pos.payment.terminal</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Gestione las terminales de pago POS aquí.</p>
        </field>
    </record>
</odoo>