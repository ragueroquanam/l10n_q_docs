<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_transaction_log_form" model="ir.ui.view">
        <field name="name">pos.transaction.log.form</field>
        <field name="model">pos.transaction.log</field>
        <field name="arch" type="xml">
            <form string="Log de Transacción POS">
                <sheet>
                    <group>
                        <field name="method"/>
                        <field name="endpoint"/>
                        <field name="state"/>
                        <field name="request_body"/>
                        <field name="response_body"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_transaction_log_tree" model="ir.ui.view">
        <field name="name">pos.transaction.log.tree</field>
        <field name="model">pos.transaction.log</field>
        <field name="arch" type="xml">
            <list string="Logs de Transacción">
                <field name="create_date"/>
                <field name="method"/>
                <field name="endpoint"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_pos_transaction_log_search" model="ir.ui.view">
        <field name="name">pos.transaction.log.search</field>
        <field name="model">pos.transaction.log</field>
        <field name="arch" type="xml">
            <search string="Buscar Logs">
                <field name="method"/>
                <field name="endpoint"/>
                <field name="state"/>
            </search>
        </field>
    </record>

    <record id="action_pos_transaction_log" model="ir.actions.act_window">
        <field name="name">Registro de Logs</field>
        <field name="res_model">pos.transaction.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pos_transaction_log_search"/>
    </record>

</odoo>