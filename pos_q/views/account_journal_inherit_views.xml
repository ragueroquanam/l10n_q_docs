<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_journal_form_inherit_pos_config" model="ir.ui.view">
        <field name="name">account.journal.form.inherit.pos.config</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Configuración POS" name="config_pos" invisible="type != 'bank'">
                    <group>
                        <field name="pos_discount_enabled"/>
                        <field name="pos_validity_date"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
