<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="account_bank_payment_file_config_direct_credits" model="account.bank.payment.file.config">
            <field name="name">CRÉDITOS DIRECTOS</field>
            <field name="code">direct_credits</field>
        </record>

        <!-- Líneas de detalle -->
        <record id="account_bank_payment_file_config_line_direct_credits_1"
                model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_direct_credits"/>
            <field name="sequence">1</field>
            <field name="name">Código de empresa asignado</field>
            <field name="description">Código fijo asignado a la empresa. Valor fijo: 112</field>
            <field name="type">fixed</field>
            <field name="value">112</field>
        </record>

        <record id="account_bank_payment_file_config_line_direct_credits_5"
                model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_direct_credits"/>
            <field name="sequence">5</field>
            <field name="name">Moneda</field>
            <field name="description">Mapeo de moneda: UYU=98 (Pesos Uruguayos), USD=01 (Dólares Americanos)</field>
            <field name="type">mapping</field>
            <field name="value">UYU=98,USD=01</field>
        </record>

        <record id="account_bank_payment_file_config_line_direct_credits_7"
                model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_direct_credits"/>
            <field name="sequence">7</field>
            <field name="name">Integrantes del grupo</field>
            <field name="description">Cantidad de integrantes del grupo. Valor fijo: 2</field>
            <field name="type">fixed</field>
            <field name="value">2</field>
        </record>

        <record id="account_bank_payment_file_config_line_direct_credits_10"
                model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_direct_credits"/>
            <field name="sequence">10</field>
            <field name="name">Devuelve IVA</field>
            <field name="description">Mapeo booleano: true=S (devuelve IVA), false=N (no devuelve)</field>
            <field name="type">mapping</field>
            <field name="value">true=S,false=N</field>
        </record>
    </data>
</odoo>
