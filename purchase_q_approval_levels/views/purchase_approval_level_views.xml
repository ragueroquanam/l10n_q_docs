<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_purchase_approval_level" model="ir.actions.act_window">
            <field name="name">Niveles de Aprobación</field>
            <field name="res_model">purchase.approval.level</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="view_purchase_approval_level_tree" model="ir.ui.view">
            <field name="name">purchase.approval.level.list</field>
            <field name="model">purchase.approval.level</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="min_amount"/>
                    <field name="max_amount"/>
                    <field name="user_groups" widget="many2many_tags"/>
                </list>
            </field>
        </record>

        <record id="view_purchase_approval_level_form" model="ir.ui.view">
            <field name="name">purchase.approval.level.form</field>
            <field name="model">purchase.approval.level</field>
            <field name="arch" type="xml">
                <form string="Nivel de Aprobación">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="min_amount"/>
                            <field name="max_amount"/>
                            <field name="user_groups" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <menuitem id="menu_purchase_approval_level"
                  name="Niveles de Aprobación"
                  parent="purchase.menu_purchase_config"
                  sequence="20"
                  action="action_purchase_approval_level"/>
    </data>
</odoo>