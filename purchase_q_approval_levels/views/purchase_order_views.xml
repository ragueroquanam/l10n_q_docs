<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_purchase_order_form_inherit" model="ir.ui.view">
            <field name="name">purchase.order.form.inherit.next_approval</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <button name="button_approve" position="attributes">
                    <attribute name="invisible" add="not allow_approval_level" separator="or"/>
                    <attribute name="groups"/>
                </button>
                <field name="date_order" position="before">
                    <field name="next_approval_level" options="{'no_open': True}" invisible="not next_approval_level"/>
                </field>
            </field>
        </record>

        <record id="view_purchase_order_kpis_tree_inherit" model="ir.ui.view">
            <field name="name">purchase.order.kpis.tree.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="arch" type="xml">
                <field name="state" position="before">
                    <field name="next_approval_level" optional="hide"/>
                </field>
            </field>
        </record>

        <record id="view_purchase_order_filter_inherit" model="ir.ui.view">
            <field name="name">purchase.order.search.next.approval.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
            <field name="arch" type="xml">

                <!-- Insertar filtro rápido después del filtro 'to_approve' -->
                <filter name="to_approve" position="after">
                    <filter name="next_approval_level_filter"
                            string="Nivel de Aprobación"
                            domain="[('next_approval_level', '!=', False)]"/>
                </filter>

                <!-- Agregar agrupación por defecto y dentro del grupo 'Group By' -->
                <filter name="order_date" context="{'group_by': 'date_order'}" position="after">
                    <filter name="group_by_next_approval_level"
                            string="Nivel de Aprobación"
                            context="{'group_by': 'next_approval_level'}"/>
                </filter>

            </field>
        </record>
    </data>
</odoo>