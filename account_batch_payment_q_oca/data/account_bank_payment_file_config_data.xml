<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="account_bank_payment_file_config_oca" model="account.bank.payment.file.config">
            <field name="name">OCA</field>
            <field name="code">oca</field>
        </record>

        <!-- Líneas de detalle oca-->
        <record id="account_bank_payment_file_config_line_oca_2" model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_oca"/>
            <field name="sequence">2</field>
            <field name="name">Moneda</field>
            <field name="description">Mapeo de monedas: UYU=858 (Pesos Uruguayos), USD=840 (Dólares Americanos)
            </field>
            <field name="type">mapping</field>
            <field name="value">UYU=858,USD=840</field>
        </record>

        <record id="account_bank_payment_file_config_line_oca_5" model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_oca"/>
            <field name="sequence">5</field>
            <field name="name">IVA</field>
            <field name="description">Indicador de IVA. Mapeo booleano: true=S (con IVA), false=N (sin IVA)</field>
            <field name="type">mapping</field>
            <field name="value">true=S,false=N</field>
        </record>

        <record id="account_bank_payment_file_config_oca_padrones" model="account.bank.payment.file.config">
            <field name="name">OCA PADRONES</field>
            <field name="code">oca_padrones</field>
        </record>

