<?xml version="1.0" ?>
<odoo>
    <record id="view_purchase_request_q_form" model="ir.ui.view">
        <field name="name">purchase.request.q.form</field>
        <field name="model">purchase.request</field>
        <field name="inherit_id" ref="purchase_request.view_purchase_request_form"/>
        <field name="arch" type="xml">
            <field name="is_editable" position="after">
                <field name="is_form_edition_disabled" invisible="1"/>
            </field>
            <xpath expr="//field[@name='company_id' and @widget='selection']" position="after">
                <field name="partner_id"/>
            </xpath>
        </field>
    </record>
</odoo>
