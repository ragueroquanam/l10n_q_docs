<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_journal_form_inherit_pos_config_plan" model="ir.ui.view">
        <field name="name">account.journal.form.pos.config.plan</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="pos_q.view_account_journal_form_inherit_pos_config"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_validity_date']" position="after">
                <field name="plan"/>
            </xpath>
        </field>
    </record>
</odoo>
