<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_form_inherit_pos_void" model="ir.ui.view">
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_draft']" position="after">
                <button name="action_open_void_wizard"
                        string="Anular o devolver"
                        type="object"
                        class="btn-secondary"
                        invisible="not is_pos_method or state!='in_process' or is_pos_manual"/>
                <button name="action_manual_refund"
                        type="object"
                        string="Devolución Manual"
                        class="btn-secondary"
                        invisible="not is_pos_manual or state!='in_process'"/>
                <button name="action_manual_cancel"
                        type="object"
                        string="Anulación Manual"
                        class="btn-secondary"
                        invisible="not is_pos_manual or state!='in_process'"/>
            </xpath>
            <xpath expr="//notebook[@name='payment_notebook']" name="pos_data" position="inside">
                <page string="Datos POS" invisible="not is_pos_method">
                    <group colspan="4">
                        <group>
                            <field name="pos_payment_terminal_id" readonly="1"/>
                            <field name="transaction_number" readonly="1"/>
                            <field name="transaction_date_str" readonly="1"/>
                            <field name="authorization_code" readonly="not is_pos_manual or state!='draft'"/>
                            <field name="card_number" readonly="1"/>
                            <field name="acquirer" readonly="1"/>
                            <field name="tax_refund" readonly="1"/>
                            <field name="pos_discount_enabled" readonly="1"/>
                            <field name="payment_datetime" readonly="1"/>
                        </group>
                        <group>
                            <field name="ticket" readonly="not is_pos_manual or state!='draft'"/>
                            <field name="batch_number" readonly="not is_pos_manual or state!='draft'"/>
                            <field name="is_credit"/>
                            <field name="installment_qty" readonly="1"
                                   required="is_credit==True"/>
                            <field name="taxable_amount" readonly="1"
                                   string="Total sin Impuestos"/>
                            <field name="invoice_amount" readonly="1"
                                   string="Total Facturado"/>
                            <field name="pos_invoice_number" readonly="1"/>
                            <field name="is_partial_payment" readonly="1"/>
                            <field name="partial_amount" readonly="1"/>
                            <field name="transaction_state" readonly="1"/>
                        </group>
                    </group>

                    <group string="Anulación-devolución POS" invisible="not is_pos_method" colspan="4">
                        <group>
                            <field name="is_voided" readonly="1"/>
                            <field name="void_type" readonly="1"/>
                        </group>
                        <group>
                            <field name="voided_transaction_id" readonly="not is_pos_manual or state!='in_process'"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
