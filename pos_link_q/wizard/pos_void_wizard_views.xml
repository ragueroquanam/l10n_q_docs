<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pos_void_wizard_form" model="ir.ui.view">
        <field name="model">pos.void.wizard</field>
        <field name="arch" type="xml">
            <form string="Void/Refund POS Payment">
                <sheet>
                    <group>
                        <field name="payment_id" readonly="1"/>
                    </group>
                    <footer>
                        <button string="Anulación-devolución manual" type="object"
                                name="action_confirm_manual" class="btn-primary"/>
                        <button string="Enviar anulación-devolución al POS " type="object"
                                name="action_confirm_pos" class="btn-primary"/>
                        <button string="Cancelar" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
