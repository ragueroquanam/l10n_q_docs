<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="account_bank_payment_file_config_fiserv" model="account.bank.payment.file.config">
            <field name="name">FISERV</field>
            <field name="code">fiserv</field>
        </record>

        <!-- Líneas de encabezado -->
        <record id="account_bank_payment_file_config_header_fiserv_1" model="account.bank.payment.file.config.line">
            <field name="config_h_id" ref="account_bank_payment_file_config_fiserv"/>
            <field name="sequence">1</field>
            <field name="name">Número de Comercio</field>
            <field name="description">Mapeo por RUT de empresa. Formato: RUT=Comercio. Ej: 213314840014=00000000,210794670016=00000000</field>
            <field name="type">mapping</field>
            <field name="value">213314840014=00000000,210794670016=00000000</field>
        </record>

        <record id="account_bank_payment_file_config_header_fiserv_2" model="account.bank.payment.file.config.line">
            <field name="config_h_id" ref="account_bank_payment_file_config_fiserv"/>
            <field name="sequence">2</field>
            <field name="name">Tipo de registro</field>
            <field name="description">Valor constante = 1 (encabezado)</field>
            <field name="type">fixed</field>
            <field name="value">1</field>
        </record>

        <record id="account_bank_payment_file_config_header_fiserv_7" model="account.bank.payment.file.config.line">
            <field name="config_h_id" ref="account_bank_payment_file_config_fiserv"/>
            <field name="sequence">7</field>
            <field name="name">Moneda</field>
            <field name="description">Dólares = D, Pesos = espacio en blanco. Mapeo: UYU= ,USD=D</field>
            <field name="type">mapping</field>
            <field name="value">UYU= ,USD=D</field>
        </record>

        <!-- Líneas de cuerpo -->
        <record id="account_bank_payment_file_config_line_fiserv_1" model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_fiserv"/>
            <field name="sequence">1</field>
            <field name="name">Número de Comercio</field>
            <field name="description">Mapeo por RUT de empresa. Formato: RUT=Comercio. Ej: 213314840014=00000000,210794670016=00000000</field>
            <field name="type">mapping</field>
            <field name="value">213314840014=00000000,210794670016=00000000</field>
        </record>

        <record id="account_bank_payment_file_config_line_fiserv_2" model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_fiserv"/>
            <field name="sequence">2</field>
            <field name="name">Tipo de registro</field>
            <field name="description">Valor constante = 2 (detalle)</field>
            <field name="type">fixed</field>
            <field name="value">2</field>
        </record>

        <record id="account_bank_payment_file_config_line_fiserv_5" model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_fiserv"/>
            <field name="sequence">5</field>
            <field name="name">Cuotas</field>
            <field name="description">Valor fijo de cuotas. Adhesiones nuevas: a partir de qué cuota inicia. Adhesiones existentes: cantidad a cancelar. Usar 001 como valor fijo.</field>
            <field name="type">fixed</field>
            <field name="value">001</field>
        </record>

        <record id="account_bank_payment_file_config_line_fiserv_7" model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_fiserv"/>
            <field name="sequence">7</field>
            <field name="name">Frecuencia DB</field>
            <field name="description">Periodicidad del débito de cuotas. Valor fijo: 01</field>
            <field name="type">fixed</field>
            <field name="value">01</field>
        </record>

        <record id="account_bank_payment_file_config_line_fiserv_13" model="account.bank.payment.file.config.line">
            <field name="config_id" ref="account_bank_payment_file_config_fiserv"/>
            <field name="sequence">13</field>
            <field name="name">Aplica devolución IVA</field>
            <field name="description">Indicador de IVA. Mapeo booleano: true=S (con IVA), false=N (sin IVA)</field>
            <field name="type">mapping</field>
            <field name="value">true=S,false=N</field>
        </record>
    </data>
</odoo>
