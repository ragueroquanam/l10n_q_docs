<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_purchase_q_extra" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.specifications</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="after">
                <field name="specifications"/>
            </xpath>
        </field>
    </record>

    <record id="view_order_line_tree_purchase_q_extra" model="ir.ui.view">
        <field name="name">purchase.order.line.tree.inherit.specifications</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price_unit']" position="after">
                <field name="specifications"/>
            </xpath>
        </field>
    </record>
</odoo>
