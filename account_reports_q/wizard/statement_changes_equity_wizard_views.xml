<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="statement_changes_equity_wizard_form" model="ir.ui.view">
        <field name="name">statement.changes.equity.wizard.form</field>
        <field name="model">statement.changes.equity.wizard</field>
        <field name="arch" type="xml">
            <form string="Anexo 2 - EEP">
                <sheet>
                    <group>
                        <field name="new_target_move" widget="radio"/>
                        <field name="fiscalyear"/>
                    </group>
                </sheet>
                <footer>
                    <button name="check_report" string="Imprimir" type="object" default_focus="1" class="oe_highlight"/>
                    <button name="check_report_excel" string="Excel" type="object" class="oe_highlight"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


    <record id="action_statement_changes_equity_wizard_form" model="ir.actions.act_window">
        <field name="name">Evolución Patrimonial</field>
        <field name="res_model">statement.changes.equity.wizard</field>
        <field name="view_id" ref="statement_changes_equity_wizard_form"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>